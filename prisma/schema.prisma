// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  firstName      String
  lastName       String
  password       String?
  role           Role      @default(CUSTOMER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  requests       Request[] @relation("CustomerRequests")
  quotedRequests Request[] @relation("QuotedRequests")
}

model Request {
  id          String   @id @default(uuid())
  name        String   @default("")
  quantity    Int      @default(1)
  description String   @default("")
  img_url     String   @default("")
  quotePrice  Float    @default(0.0)
  finalPrice  Float    @default(0.0)
  status      Status   @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customerId String
  user       User    @relation("CustomerRequests", fields: [customerId], references: [id])

  quotedById String?
  quotedBy   User?   @relation("QuotedRequests", fields: [quotedById], references: [id])
}

enum Role {
  ADMIN
  CUSTOMER
  EMPLOYEE
}

enum Status {
  PENDING
  QUOTED
  APPROVED
  PURCHASED
  AT_WAREHOUSE
  SHIPPED
  DONE
}
